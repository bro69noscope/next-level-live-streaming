{
  // Main repository servers
  repository: {
    python: {
      host: "127.0.0.1",
      port: 50000,
      protocol: "websocket",
      url: "ws://localhost:50000",
      tokens: {
        url: {
          token: "{{REPOSITORY_PYTHON_WS}}",
          scope_keys: {
            obs: "url",
            default: "url",
          },
        },
        port: {
          token: "{{REPOSITORY_PYTHON_PORT}}",
        },
      },
    },
  },
  // OBS servers
  obs: {
    production: {
      host: "127.0.0.1",
      port: 51000,
      protocol: "websocket",
      token: "{{OBS_PRODUCTION_PORT}}",
      scope_keys: {
        obs: "server_port",
        default: "port",
      },
    },
    portable_vcam: {
      host: "127.0.0.1",
      port: 51001,
      protocol: "websocket",
      token: "{{OBS_PORTABLE_VCAM_PORT}}",
      scope_keys: {
        obs: "server_port",
        default: "port",
      },
    },
    portable_ftp: {
      host: "127.0.0.1",
      port: 51002,
      protocol: "websocket",
      token: "{{OBS_PORTABLE_FTP_PORT}}",
      scope_keys: {
        obs: "server_port",
        default: "port",
      },
    },
  },
  // Streamer.bot servers
  streamerbot: {
    production: {
      streamerbot: {
        host: "127.0.0.1",
        port: 52000,
        protocol: "websocket",
        token: "{{STREAMERBOT_PRODUCTION_PORT}}",
      },
      integrations: {
        streamdeck: {
          host: "127.0.0.1",
          port: 52100,
          protocol: "websocket",
          token: "{{STREAMERBOT_PRODUCTION_STREAMDECK_PORT}}",
        },
      },
    },
    ftp: {
      streamerbot: {
        host: "127.0.0.1",
        port: 52001,
        protocol: "websocket",
        token: "{{STREAMERBOT_FTP_PORT}}",
      },
      integrations: {
        streamdeck: {
          host: "127.0.0.1",
          port: 52200,
          protocol: "websocket",
          token: "{{STREAMERBOT_FTP_STREAMDECK_PORT}}",
        },
      },
    },
  },
  // Internal subprocess socket servers
  subprocesses: {
    shopwatcher: {
      port: 59000,
      token: "{{SHOPWATCHER_PORT}}",
    },
    pregamespy: {
      port: 59001,
      token: "{{PREGAMESPY_PORT}}",
    },
    robeau: {
      port: 59002,
      token: "{{ROBEAU_PORT}}",
    },
    synonym_adder: {
      port: 59003,
      token: "{{SYNONYM_ADDER_PORT}}",
    },
  },
}
